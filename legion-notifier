#!/usr/bin/env bash
# legion-notifier — flash the Legion Go stick-ring LEDs by invoking the
# mapper's D-Bus service (net.legiongo.Mapper). Also sends a GNOME
# notification so the user gets a desktop banner in parallel.
#
# Usage:
#   legion-notifier [EXIT_CODE]
#     0        → green × 2 flashes  ("Command succeeded")
#     non-zero → red   × 2 flashes  ("Command failed (exit N)")
#
#   legion-notifier --color NAME [--count N] [--summary TEXT] [--body TEXT]
#     NAME must be a color defined in config (defaults: green, red, blue,
#     yellow, white). See notification_colors in config.json.
#
#   legion-notifier run [--count N] [--color-ok NAME] [--color-ko NAME] \
#                        [--silent] [--] CMD [ARGS...]
#     Wrap a command: run CMD, flash green on exit 0 or red on non-zero,
#     and propagate the command's exit code. stdin/stdout/stderr are
#     passed through unchanged. Example:  legion-notifier run make install
#
#   legion-notifier --silent ...   Do not send the GNOME banner (LED only).
#   legion-notifier --help

set -u

usage() {
    sed -n '2,22p' "$0" | sed 's/^# \{0,1\}//'
}

color=""
count=2
summary=""
body=""
exit_code=""
silent=0
wrap_rc=""

if [[ "${1:-}" == "run" ]]; then
    shift
    run_count=2
    run_color_ok="green"
    run_color_ko="red"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)  usage; exit 0 ;;
            --count)    run_count="$2"; shift 2 ;;
            --color-ok) run_color_ok="$2"; shift 2 ;;
            --color-ko) run_color_ko="$2"; shift 2 ;;
            --silent)   silent=1; shift ;;
            --)         shift; break ;;
            -*)
                echo "legion-notifier run: unknown flag $1" >&2
                exit 2
                ;;
            *) break ;;   # start of wrapped command
        esac
    done
    if [[ $# -eq 0 ]]; then
        echo "legion-notifier run: no command given" >&2
        echo "Usage: legion-notifier run [flags] [--] CMD [ARGS...]" >&2
        exit 2
    fi
    cmd_name="$1"
    "$@"
    wrap_rc=$?
    count="$run_count"
    if [[ "$wrap_rc" -eq 0 ]]; then
        color="$run_color_ok"
        summary="$cmd_name succeeded"
    else
        color="$run_color_ko"
        summary="$cmd_name failed (exit $wrap_rc)"
    fi
else
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help) usage; exit 0 ;;
            --color)   color="$2"; shift 2 ;;
            --count)   count="$2"; shift 2 ;;
            --summary) summary="$2"; shift 2 ;;
            --body)    body="$2"; shift 2 ;;
            --silent)  silent=1; shift ;;
            --)        shift; break ;;
            -*) echo "legion-notifier: unknown flag $1" >&2; exit 2 ;;
            *)
                if [[ -z "$exit_code" && "$1" =~ ^[0-9]+$ ]]; then
                    exit_code="$1"; shift
                elif [[ -z "$summary" ]]; then
                    summary="$1"; shift
                elif [[ -z "$body" ]]; then
                    body="$1"; shift
                else
                    shift
                fi
                ;;
        esac
    done

    if [[ -z "$color" ]]; then
        [[ -z "$exit_code" ]] && exit_code=0
        if [[ "$exit_code" -eq 0 ]]; then
            color="green"
            [[ -z "$summary" ]] && summary="Command succeeded"
        else
            color="red"
            [[ -z "$summary" ]] && summary="Command failed (exit $exit_code)"
        fi
    fi
fi

[[ -z "$summary" ]] && summary="legion-notifier"

# Flash the LEDs via the mapper's D-Bus service. Silently succeed if the
# mapper isn't running or the service isn't registered yet — we don't want
# notifier failures to break scripts using `cmd; legion-notifier $?`.
if command -v gdbus >/dev/null 2>&1; then
    gdbus call --session \
        --dest net.legiongo.Mapper \
        --object-path /net/legiongo/Notifier \
        --method net.legiongo.Notifier.Flash \
        "$color" "$count" >/dev/null 2>&1 || true
fi

if [[ "$silent" -eq 0 ]]; then
    if command -v notify-send >/dev/null 2>&1; then
        if [[ -n "$body" ]]; then
            notify-send --app-name="legion-notifier" "$summary" "$body"
        else
            notify-send --app-name="legion-notifier" "$summary"
        fi
    fi
fi

# When used as `legion-notifier run …`, propagate the wrapped command's
# exit code so the wrapper is transparent in shell pipelines and scripts.
if [[ -n "$wrap_rc" ]]; then
    exit "$wrap_rc"
fi
